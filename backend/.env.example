# Server Configuration
PORT=3001
NODE_ENV=development

# CORS - Set to your frontend URL in production (e.g. https://your-app.netlify.app)
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
# For local dev: postgresql://user:password@localhost:5432/dbname
# Render provides DATABASE_URL when you add a PostgreSQL database
DATABASE_URL=postgresql://user:password@localhost:5432/mvx_subscriptions

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# MultiversX WebSocket: subscribe payloads per socket session (MVX default max ~10). Opens extra connections when exceeded.
MVX_WS_MAX_SUBSCRIPTIONS_PER_SOCKET=10

# Max subscription rows per wallet (API also returns this as maxSubscriptionsPerUser).
MAX_SUBSCRIPTIONS_PER_USER=10

# MultiversX API
MVX_API_MAINNET=https://api.multiversx.com
MVX_API_TESTNET=https://testnet-api.multiversx.com
MVX_API_DEVNET=https://devnet-api.multiversx.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# Webhook Settings
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_RETRIES=3
# Delete webhook_logs and delivered_transfers rows older than this many days (0 = disable). Default: 7
WEBHOOK_LOG_RETENTION_DAYS=7
# How often to run cleanup in ms (default: 86400000 = 24h)
# WEBHOOK_LOG_CLEANUP_INTERVAL_MS=86400000

# Transaction confirmation polling (ON by default)
# The MultiversX WebSocket rarely sends "success"—we poll the API to deliver confirmed events.
# Set to true only if you need to disable (e.g. API rate limits on high volume):
# DISABLE_TX_CONFIRMATION_POLL=true

# Logging
LOG_LEVEL=info
# Optional: extra diagnostics when no subscription matches (also enabled when LOG_LEVEL=debug)
# WEBSOCKET_FILTER_DEBUG=1

# Thin WS payloads: disable REST GET /transactions/:hash enrichment (not recommended).
# DISABLE_WS_TRANSFER_ENRICHMENT=true

# Supabase (Make.com blueprint templates — list via anon key; admin upload uses service role)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Wallet allowed to create/update/delete templates (defaults to project admin if unset)
MAKEX_TEMPLATES_ADMIN_WALLET=erd1h9hm0gnkgn888ly9zgnswsjajprk2fkszndwhm28xkcay66xnnesdyzcs6