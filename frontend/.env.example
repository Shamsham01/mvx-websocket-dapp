REACT_APP_API_URL=http://localhost:3001/api
REACT_APP_ENV=development

# Supabase REST (template list + free trial whitelist)
# REACT_APP_SUPABASE_URL=https://your-project.supabase.co
# REACT_APP_SUPABASE_ANON_KEY=your-anon-key
# MultiversX network: mainnet | testnet | devnet (default: mainnet)
# REACT_APP_MVX_ENV=mainnet

# Required for WalletConnect (xPortal, drfi): get free project ID at https://cloud.walletconnect.com/
# Without this, xPortal/drfi options are hidden in the Connect Wallet panel
# REACT_APP_WALLETCONNECT_V2_PROJECT_ID=your_project_id_here
